# --- Required ---
# A 32+ char random string. Generate with: openssl rand -base64 33
AUTH_SECRET="replace-me-with-openssl-rand-base64-33"

# Local SQLite by default. For production, swap to Postgres:
# DATABASE_URL="postgresql://user:pass@host:5432/globical"
DATABASE_URL="file:./dev.db"

# --- Optional OAuth providers (each one auto-enables when both ID + secret are set) ---
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Apple: https://developer.apple.com/account/resources/identifiers/list/serviceId
AUTH_APPLE_ID=""
AUTH_APPLE_SECRET=""

# --- Optional email (magic links). If unset, magic link URLs print to the server console. ---
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="Globical <hello@globical.app>"

# Public site URL (used for email links + share URLs). Optional in dev.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cron secrets ---
# Required in production: protect the cron endpoints from random callers.
# Generate each with: openssl rand -base64 24
# Leave unset in dev to let curl hit the endpoints without auth.
DROPS_REFRESH_SECRET=""
PREDICTIONS_SWEEP_SECRET=""

# --- Error tracking (Sentry) ---
# Get DSN at https://sentry.io. Free tier: 5K errors + 50 replays / month.
# All Sentry features are skipped when DSN is empty — safe to leave blank in dev.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""          # for source-map upload during build only

# --- Product analytics (PostHog) ---
# Get key at https://app.posthog.com. Free tier: 1M events/month.
# Only fires when the user has opted in via the consent banner.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"  # or "https://eu.i.posthog.com"

# --- Uptime monitoring (BetterStack) ---
# No env var needed. Set up your monitor to ping:
#   GET ${NEXT_PUBLIC_APP_URL}/api/health
# Expects HTTP 200 with { ok: true } when healthy.
